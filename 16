def _safe_sql(val):
    if val is None:
        return ""
    return str(val).replace("'", "''")


def _status_badge(status):
    cls_map = {"Queued": "status-queued", "In Progress": "status-inprogress", "On Hold": "status-onhold", "Closed": "status-closed"}
    cls = cls_map.get(status, "status-queued")
    return f'<span class="status-badge {cls}">{status}</span>'


def _progress_bar_html(pct):
    pct = max(0, min(100, float(pct or 0)))
    if pct >= 100:
        color = "#22c55e"
    elif pct >= 60:
        color = "#3b82f6"
    elif pct >= 30:
        color = "#f59e0b"
    else:
        color = "#ef4444"
    return f'<div class="progress-bar-outer"><div class="progress-bar-inner" style="width:{pct}%;background:{color};"></div></div>'


def _metric_card(value, label, color="blue"):
    return f'<div class="metric-card mc-{color}"><p class="metric-value">{value}</p><p class="metric-label">{label}</p></div>'


def _check_tables_exist():
    if session is None:
        return False, [TBL_TASKS, TBL_NOTES]
    missing = []
    for tbl in [TBL_TASKS, TBL_NOTES]:
        try:
            session.sql(f"SELECT 1 FROM {tbl} LIMIT 1").collect()
        except Exception:
            missing.append(tbl)
    return len(missing) == 0, missing


# ── Data Access ──
def load_active_members():
    try:
        df = session.sql(f"SELECT NAME FROM {TBL_MEMBERS} WHERE ACTIVE_STATUS = 'Active' ORDER BY NAME").to_pandas()
        return df["NAME"].tolist() if not df.empty else []
    except Exception:
        return []



def load_tasks(status_filter=None, owner_filter=None, platform_filter=None,
               start_from=None, start_to=None):
    try:
        where = []
        if status_filter and status_filter != "All":
            where.append(f"STATUS = '{_safe_sql(status_filter)}'")
        if owner_filter and owner_filter != "All":
            where.append(f"OWNER = '{_safe_sql(owner_filter)}'")
        if platform_filter and platform_filter != "All":
            where.append(f"PLATFORM_AREA = '{_safe_sql(platform_filter)}'")
        if start_from:
            where.append(f"START_DATE >= '{start_from}'")
        if start_to:
            where.append(f"START_DATE <= '{start_to}'")
        sql = f"SELECT * FROM {TBL_TASKS}"
        if where:
            sql += " WHERE " + " AND ".join(where)
        sql += " ORDER BY CASE STATUS WHEN 'In Progress' THEN 1 WHEN 'Queued' THEN 2 WHEN 'On Hold' THEN 3 ELSE 4 END, UPDATED_AT DESC"
        return session.sql(sql).to_pandas()
    except Exception as e:
        st.error(f"Error loading tasks: {e}")
        return pd.DataFrame()


def load_notes_for_task(task_id):
    try:
        df = session.sql(f"SELECT * FROM {TBL_NOTES} WHERE TASK_ID = {int(task_id)} ORDER BY CREATED_AT DESC").to_pandas()
        return df
    except Exception:
        return pd.DataFrame()


def get_distinct_platforms():
    try:
        df = session.sql(f"SELECT DISTINCT PLATFORM_AREA FROM {TBL_TASKS} WHERE PLATFORM_AREA IS NOT NULL AND PLATFORM_AREA != '' ORDER BY PLATFORM_AREA").to_pandas()
        return df["PLATFORM_AREA"].tolist() if not df.empty else []
    except Exception:
        return []


def get_distinct_owners():
    try:
        df = session.sql(f"SELECT DISTINCT OWNER FROM {TBL_TASKS} ORDER BY OWNER").to_pandas()
        return df["OWNER"].tolist() if not df.empty else []
    except Exception:
        return []



def insert_task(title, reason, platform, owner, reviewer, start_dt, end_dt, status, effort, pct, jira):
    try:
        end_val = f"'{end_dt}'" if end_dt else "NULL"
        rev_val = f"'{_safe_sql(reviewer)}'" if reviewer else "NULL"
        reason_val = f"'{_safe_sql(reason)}'" if reason else "NULL"
        platform_val = f"'{_safe_sql(platform)}'" if platform else "NULL"
        jira_val = f"'{_safe_sql(jira)}'" if jira else "NULL"
        session.sql(f"""
            INSERT INTO {TBL_TASKS} (TASK_TITLE, BUSINESS_REASON, PLATFORM_AREA, OWNER, REVIEWER,
                               START_DATE, END_DATE, STATUS, EFFORT_DAYS, COMPLETION_PCT, JIRA_REFERENCE)
            VALUES ('{_safe_sql(title)}', {reason_val}, {platform_val}, '{_safe_sql(owner)}', {rev_val},
                    '{start_dt}', {end_val}, '{_safe_sql(status)}', {float(effort)}, {float(pct)}, {jira_val})
        """).collect()
        return True, f"Task '{title}' created successfully."
    except Exception as e:
        return False, f"Error creating task: {e}"


def update_task(task_id, title, reason, platform, owner, reviewer, start_dt, end_dt, status, effort, pct, jira):
    try:
        end_val = f"'{end_dt}'" if end_dt else "NULL"
        rev_val = f"'{_safe_sql(reviewer)}'" if reviewer else "NULL"
        reason_val = f"'{_safe_sql(reason)}'" if reason else "NULL"
        platform_val = f"'{_safe_sql(platform)}'" if platform else "NULL"
        jira_val = f"'{_safe_sql(jira)}'" if jira else "NULL"
        session.sql(f"""
            UPDATE {TBL_TASKS} SET
                TASK_TITLE = '{_safe_sql(title)}',
                BUSINESS_REASON = {reason_val},
                PLATFORM_AREA = {platform_val},
                OWNER = '{_safe_sql(owner)}',
                REVIEWER = {rev_val},
                START_DATE = '{start_dt}',
                END_DATE = {end_val},
                STATUS = '{_safe_sql(status)}',
                EFFORT_DAYS = {float(effort)},
                COMPLETION_PCT = {float(pct)},
                JIRA_REFERENCE = {jira_val},
                UPDATED_AT = CURRENT_TIMESTAMP()
            WHERE TASK_ID = {int(task_id)}
        """).collect()
        return True, "Task updated successfully."
    except Exception as e:
        return False, f"Error updating task: {e}"


def delete_task(task_id):
    try:
        session.sql(f"DELETE FROM {TBL_NOTES} WHERE TASK_ID = {int(task_id)}").collect()
        session.sql(f"DELETE FROM {TBL_TASKS} WHERE TASK_ID = {int(task_id)}").collect()
        return True, "Task deleted successfully."
    except Exception as e:
        return False, f"Error deleting task: {e}"


def insert_note(task_id, note_text, created_by):
    try:
        by_val = f"'{_safe_sql(created_by)}'" if created_by else "NULL"
        session.sql(f"""
            INSERT INTO {TBL_NOTES} (TASK_ID, NOTE_TEXT, CREATED_BY)
            VALUES ({int(task_id)}, '{_safe_sql(note_text)}', {by_val})
        """).collect()
        return True, "Note added."
    except Exception as e:
        return False, f"Error adding note: {e}"


def validate_task(title, owner, start_dt, end_dt, status, effort, pct):
    errors = []
    if not title or not title.strip():
        errors.append("Task Title is required.")
    if not owner:
        errors.append("Owner is required.")
    if not start_dt:
        errors.append("Start Date is required.")
    if status == "Closed" and not end_dt:
        errors.append("End Date is required when status is Closed.")
    if end_dt and start_dt and end_dt < start_dt:
        errors.append("End Date cannot be before Start Date.")
    if effort is not None and effort < 0:
        errors.append("Effort (Days) cannot be negative.")
    if pct is not None and (pct < 0 or pct > 100):
        errors.append("Completion % must be between 0 and 100.")
    if pct == 100 and status != "Closed":
        errors.append("Status should be 'Closed' when Completion is 100%.")
    return errors


