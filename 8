with tab4:
    st.markdown('<div class="section-label">Import Data from CSV / Excel</div>', unsafe_allow_html=True)
    st.markdown("Upload a file, map its columns to the task fields, preview, and bulk-insert into Snowflake. This is designed as a one-time migration tool.")

    TASK_FIELDS = {
        "-- Skip --": None,
        "Task Title *": "TASK_TITLE",
        "Business Reason": "BUSINESS_REASON",
        "Platform / Area": "PLATFORM_AREA",
        "Owner *": "OWNER",
        "Reviewer": "REVIEWER",
        "Start Date *": "START_DATE",
        "End Date": "END_DATE",
        "Status": "STATUS",
        "Effort (Days)": "EFFORT_DAYS",
        "Completion %": "COMPLETION_PCT",
        "JIRA / Reference": "JIRA_REFERENCE",
        "Comments / Notes": "PROGRESS_NOTE",
    }

    uploaded_file = st.file_uploader("Upload CSV or Excel file", type=["csv", "xlsx", "xls"], key="import_file")

    if uploaded_file is not None:
        # Read the file
        try:
            if uploaded_file.name.endswith(".csv"):
                raw_df = pd.read_csv(uploaded_file)
            else:
                raw_df = pd.read_excel(uploaded_file)

            st.markdown(f'<div class="section-label" style="margin-top:16px;">File Preview ({len(raw_df)} rows, {len(raw_df.columns)} columns)</div>', unsafe_allow_html=True)
            st.dataframe(raw_df.head(10), use_container_width=True, hide_index=True)

            file_columns = ["-- Skip --"] + list(raw_df.columns)

            # Column mapping
            st.markdown('<div class="section-label" style="margin-top:16px;">Column Mapping</div>', unsafe_allow_html=True)
            st.markdown("Map each task field to a column from your file. Fields marked * are required.")

            mapping = {}
            mc1, mc2 = st.columns(2)

            field_list = list(TASK_FIELDS.keys())
            half = len(field_list) // 2

            with mc1:
                for field_label in field_list[:half]:
                    if field_label == "-- Skip --":
                        continue
                    mapping[field_label] = st.selectbox(
                        field_label,
                        options=file_columns,
                        index=0,
                        key=f"map_{field_label}"
                    )

            with mc2:
                for field_label in field_list[half:]:
                    if field_label == "-- Skip --":
                        continue
                    mapping[field_label] = st.selectbox(
                        field_label,
                        options=file_columns,
                        index=0,
                        key=f"map_{field_label}"
                    )

            # Default status for unmapped status column
            st.markdown('<div class="section-label" style="margin-top:16px;">Default Values</div>', unsafe_allow_html=True)
            default_status = st.selectbox("Default Status (for rows without a status)", STATUS_OPTIONS, index=0, key="import_default_status")
            default_owner = st.selectbox("Default Owner (for rows without an owner)", options=[""] + load_active_members(), format_func=lambda x: "-- Leave blank --" if x == "" else x, key="import_default_owner")

            # Preview mapped data
            if st.button("Preview Mapped Data", key="preview_mapped", use_container_width=True):
                preview_rows = []
                errors_found = 0

                for idx, row in raw_df.iterrows():
                    mapped_row = {}
                    for field_label, file_col in mapping.items():
                        db_col = TASK_FIELDS.get(field_label)
                        if db_col is None:
                            continue
                        if file_col == "-- Skip --":
                            mapped_row[db_col] = None
                        else:
                            val = row.get(file_col)
                            if pd.isna(val):
                                mapped_row[db_col] = None
                            else:
                                mapped_row[db_col] = str(val).strip()

                    # Apply defaults
                    if not mapped_row.get("STATUS"):
                        mapped_row["STATUS"] = default_status
                    if not mapped_row.get("OWNER") and default_owner:
                        mapped_row["OWNER"] = default_owner

                    # Validate required fields
                    row_errors = []
                    if not mapped_row.get("TASK_TITLE"):
                        row_errors.append("Missing Title")
                        errors_found += 1
                    if not mapped_row.get("OWNER"):
                        row_errors.append("Missing Owner")
                        errors_found += 1

                    mapped_row["_ROW"] = idx + 1
                    mapped_row["_ERRORS"] = ", ".join(row_errors) if row_errors else ""
                    preview_rows.append(mapped_row)

                preview_df = pd.DataFrame(preview_rows)
                st.session_state["import_preview"] = preview_df
                st.session_state["import_errors"] = errors_found

            # Show preview if available
            if st.session_state.get("import_preview") is not None:
                preview_df = st.session_state["import_preview"]
                errors_found = st.session_state.get("import_errors", 0)

                st.markdown(f'<div class="section-label" style="margin-top:16px;">Mapped Preview ({len(preview_df)} rows)</div>', unsafe_allow_html=True)

                if errors_found > 0:
                    st.markdown(f'<div class="warning-box">{errors_found} validation error(s) found. Rows with errors will be skipped during import. Check the ERRORS column below.</div>', unsafe_allow_html=True)

                display_cols = ["_ROW", "TASK_TITLE", "OWNER", "REVIEWER", "PLATFORM_AREA", "STATUS",
                               "START_DATE", "END_DATE", "EFFORT_DAYS", "COMPLETION_PCT", "JIRA_REFERENCE", "PROGRESS_NOTE", "_ERRORS"]
                available = [c for c in display_cols if c in preview_df.columns]
                st.dataframe(preview_df[available].head(20), use_container_width=True, hide_index=True)

                if len(preview_df) > 20:
                    st.caption(f"Showing first 20 of {len(preview_df)} rows.")

                # Import button
                valid_rows = preview_df[preview_df["_ERRORS"] == ""]
                st.markdown(f"**{len(valid_rows)}** rows ready to import, **{len(preview_df) - len(valid_rows)}** will be skipped.")

                if len(valid_rows) > 0:
                    if st.button("Import Data to Snowflake", type="primary", use_container_width=True, key="do_import"):
                        success_count = 0
                        fail_count = 0
                        fail_messages = []

                        progress_bar = st.progress(0)
                        status_text = st.empty()

                        for i, (_, row) in enumerate(valid_rows.iterrows()):
                            try:
                                title = row.get("TASK_TITLE", "")
                                reason = row.get("BUSINESS_REASON") if pd.notna(row.get("BUSINESS_REASON")) else None
                                platform = row.get("PLATFORM_AREA") if pd.notna(row.get("PLATFORM_AREA")) else None
                                owner = row.get("OWNER", "")
                                reviewer = row.get("REVIEWER") if pd.notna(row.get("REVIEWER")) else None
                                status = row.get("STATUS", "Queued")
                                jira = row.get("JIRA_REFERENCE") if pd.notna(row.get("JIRA_REFERENCE")) else None

                                # Parse dates
                                start_dt = None
                                if row.get("START_DATE") and pd.notna(row.get("START_DATE")):
                                    try:
                                        start_dt = pd.to_datetime(row["START_DATE"]).date()
                                    except Exception:
                                        start_dt = date.today()
                                else:
                                    start_dt = date.today()

                                end_dt = None
                                if row.get("END_DATE") and pd.notna(row.get("END_DATE")):
                                    try:
                                        end_dt = pd.to_datetime(row["END_DATE"]).date()
                                    except Exception:
                                        end_dt = None

                                # Parse numbers
                                effort = 0.0
                                if row.get("EFFORT_DAYS") and pd.notna(row.get("EFFORT_DAYS")):
                                    try:
                                        effort = float(row["EFFORT_DAYS"])
                                    except Exception:
                                        effort = 0.0

                                pct = 0.0
                                if row.get("COMPLETION_PCT") and pd.notna(row.get("COMPLETION_PCT")):
                                    try:
                                        pct = float(row["COMPLETION_PCT"])
                                        if pct > 1 and pct <= 100:
                                            pass  # already percentage
                                        elif pct <= 1:
                                            pct = pct * 100  # convert decimal to %
                                    except Exception:
                                        pct = 0.0

                                # Validate status
                                if status not in STATUS_OPTIONS:
                                    status = default_status

                                ok, msg = insert_task(title, reason, platform, owner, reviewer,
                                                      start_dt, end_dt, status, effort, pct, jira)
                                if ok:
                                    success_count += 1
                                    # Insert progress note if comments/notes column was mapped
                                    note_text = row.get("PROGRESS_NOTE")
                                    if note_text and pd.notna(note_text) and str(note_text).strip():
                                        try:
                                            # Get the task ID of the just-inserted task
                                            last_task = session.sql(f"SELECT MAX(TASK_ID) AS TID FROM {TBL_TASKS} WHERE TASK_TITLE = '{_safe_sql(title)}' AND OWNER = '{_safe_sql(owner)}'").to_pandas()
                                            if not last_task.empty and last_task["TID"].iloc[0]:
                                                new_task_id = int(last_task["TID"].iloc[0])
                                                insert_note(new_task_id, str(note_text).strip(), "Imported")
                                        except Exception:
                                            pass  # note insert failure is non-critical
                                else:
                                    fail_count += 1
                                    fail_messages.append(f"Row {int(row.get('_ROW', i+1))}: {msg}")

                            except Exception as e:
                                fail_count += 1
                                fail_messages.append(f"Row {int(row.get('_ROW', i+1))}: {str(e)}")

                            progress_bar.progress((i + 1) / len(valid_rows))
                            status_text.text(f"Processing row {i+1} of {len(valid_rows)}...")

                        status_text.empty()
                        progress_bar.empty()

                        # Results
                        if success_count > 0:
                            st.markdown(f'<div class="success-box">Successfully imported {success_count} task(s) into Snowflake.</div>', unsafe_allow_html=True)
                        if fail_count > 0:
                            st.error(f"{fail_count} row(s) failed to import:")
                            for fm in fail_messages[:10]:
                                st.caption(fm)
                            if len(fail_messages) > 10:
                                st.caption(f"...and {len(fail_messages) - 10} more.")

                        # Clear preview
                        st.session_state["import_preview"] = None
                        st.session_state["import_errors"] = 0
                else:
                    st.warning("No valid rows to import. Fix the errors in your file and try again.")

        except Exception as e:
            st.error(f"Error reading file: {e}")
