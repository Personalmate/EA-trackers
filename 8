        return df["PLATFORM_AREA"].tolist() if not df.empty else []
    except Exception:
        return []


def get_distinct_owners():
    try:
        df = session.sql(f"SELECT DISTINCT OWNER FROM {TBL_TASKS} ORDER BY OWNER").to_pandas()
        return df["OWNER"].tolist() if not df.empty else []
    except Exception:
