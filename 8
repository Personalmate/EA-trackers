def insert_member(name, role, active_status, default_reviewer, notes):
    try:
        check = session.sql(f"SELECT COUNT(*) AS CNT FROM {TBL_MEMBERS} WHERE UPPER(NAME) = UPPER('{_safe_sql(name)}')").to_pandas()
        if check["CNT"].iloc[0] > 0:
            return False, f"A team member named '{name}' already exists."
        dr = f"'{_safe_sql(default_reviewer)}'" if default_reviewer else "NULL"
        nt = f"'{_safe_sql(notes)}'" if notes else "NULL"
        session.sql(f"""
            INSERT INTO {TBL_MEMBERS} (NAME, ROLE, ACTIVE_STATUS, DEFAULT_REVIEWER, NOTES)
            VALUES ('{_safe_sql(name)}', '{_safe_sql(role)}', '{_safe_sql(active_status)}', {dr}, {nt})
        """).collect()
        return True, f"Team member '{name}' added successfully."
    except Exception as e:
        return False, f"Error adding member: {e}"


def update_member(member_id, name, role, active_status, default_reviewer, notes):
    try:
        check = session.sql(f"SELECT COUNT(*) AS CNT FROM {TBL_MEMBERS} WHERE UPPER(NAME) = UPPER('{_safe_sql(name)}') AND MEMBER_ID != {int(member_id)}").to_pandas()
        if check["CNT"].iloc[0] > 0:
            return False, f"Another team member named '{name}' already exists."
        if active_status == "Inactive":
            open_tasks = session.sql(f"SELECT COUNT(*) AS CNT FROM {TBL_TASKS} WHERE (OWNER = '{_safe_sql(name)}' OR REVIEWER = '{_safe_sql(name)}') AND STATUS != 'Closed'").to_pandas()
            if open_tasks["CNT"].iloc[0] > 0:
                return False, f"Cannot deactivate '{name}' -- they have {int(open_tasks['CNT'].iloc[0])} open task(s). Close or reassign those tasks first."
        dr = f"'{_safe_sql(default_reviewer)}'" if default_reviewer else "NULL"
        nt = f"'{_safe_sql(notes)}'" if notes else "NULL"
        session.sql(f"""
            UPDATE {TBL_MEMBERS} SET
                NAME = '{_safe_sql(name)}',
                ROLE = '{_safe_sql(role)}',
                ACTIVE_STATUS = '{_safe_sql(active_status)}',
                DEFAULT_REVIEWER = {dr},
                NOTES = {nt},
                UPDATED_AT = CURRENT_TIMESTAMP()
            WHERE MEMBER_ID = {int(member_id)}
        """).collect()
        return True, f"Team member '{name}' updated successfully."
    except Exception as e:
        return False, f"Error updating member: {e}"


def delete_member(member_id, name):
    try:
        open_tasks = session.sql(f"SELECT COUNT(*) AS CNT FROM {TBL_TASKS} WHERE (OWNER = '{_safe_sql(name)}' OR REVIEWER = '{_safe_sql(name)}') AND STATUS != 'Closed'").to_pandas()
        if open_tasks["CNT"].iloc[0] > 0:
            return False, f"Cannot delete '{name}' -- they have {int(open_tasks['CNT'].iloc[0])} open task(s)."
        session.sql(f"DELETE FROM {TBL_MEMBERS} WHERE MEMBER_ID = {int(member_id)}").collect()
        return True, f"Team member '{name}' deleted."
    except Exception as e:
        return False, f"Error deleting member: {e}"


def insert_task(title, reason, platform, owner, reviewer, start_dt, end_dt, status, effort, pct, jira):
    try:
        end_val = f"'{end_dt}'" if end_dt else "NULL"
        rev_val = f"'{_safe_sql(reviewer)}'" if reviewer else "NULL"
        reason_val = f"'{_safe_sql(reason)}'" if reason else "NULL"
        platform_val = f"'{_safe_sql(platform)}'" if platform else "NULL"
        jira_val = f"'{_safe_sql(jira)}'" if jira else "NULL"
        session.sql(f"""
            INSERT INTO {TBL_TASKS} (TASK_TITLE, BUSINESS_REASON, PLATFORM_AREA, OWNER, REVIEWER,
                               START_DATE, END_DATE, STATUS, EFFORT_DAYS, COMPLETION_PCT, JIRA_REFERENCE)
            VALUES ('{_safe_sql(title)}', {reason_val}, {platform_val}, '{_safe_sql(owner)}', {rev_val},
                    '{start_dt}', {end_val}, '{_safe_sql(status)}', {float(effort)}, {float(pct)}, {jira_val})
        """).collect()
        return True, f"Task '{title}' created successfully."
    except Exception as e:
        return False, f"Error creating task: {e}"


