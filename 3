Team Effort Tracker — Streamlit in Snowflake (SiS) Application
================================================================
Replaces the Excel-based effort tracker with a structured internal app.

DDL — Run these statements ONCE in Snowflake before launching the app:
----------------------------------------------------------------------

CREATE TABLE IF NOT EXISTS TEAM_MEMBERS (
    MEMBER_ID       NUMBER AUTOINCREMENT START 1 INCREMENT 1,
    NAME            VARCHAR(200)   NOT NULL,
    ROLE            VARCHAR(50)    NOT NULL DEFAULT 'Contributor',
    ACTIVE_STATUS   VARCHAR(20)    NOT NULL DEFAULT 'Active',
    DEFAULT_REVIEWER VARCHAR(200),
    NOTES           VARCHAR(2000),
    CREATED_AT      TIMESTAMP_NTZ  DEFAULT CURRENT_TIMESTAMP(),
    UPDATED_AT      TIMESTAMP_NTZ  DEFAULT CURRENT_TIMESTAMP(),
    PRIMARY KEY (MEMBER_ID),
    UNIQUE (NAME)
);

CREATE TABLE IF NOT EXISTS TASKS (
    TASK_ID         NUMBER AUTOINCREMENT START 1 INCREMENT 1,
    TASK_TITLE      VARCHAR(500)   NOT NULL,
    BUSINESS_REASON VARCHAR(2000),
    PLATFORM_AREA   VARCHAR(200),
    OWNER           VARCHAR(200)   NOT NULL,
    REVIEWER        VARCHAR(200),
    START_DATE      DATE           NOT NULL,
    END_DATE        DATE,
    STATUS          VARCHAR(50)    NOT NULL DEFAULT 'Queued',
    EFFORT_DAYS     NUMBER(10,2)   DEFAULT 0,
    COMPLETION_PCT  NUMBER(5,2)    DEFAULT 0,
    JIRA_REFERENCE  VARCHAR(500),
    CREATED_AT      TIMESTAMP_NTZ  DEFAULT CURRENT_TIMESTAMP(),
    UPDATED_AT      TIMESTAMP_NTZ  DEFAULT CURRENT_TIMESTAMP(),
    PRIMARY KEY (TASK_ID)
);

CREATE TABLE IF NOT EXISTS PROGRESS_NOTES (
    NOTE_ID     NUMBER AUTOINCREMENT START 1 INCREMENT 1,
    TASK_ID     NUMBER         NOT NULL,
    NOTE_TEXT   VARCHAR(4000)  NOT NULL,
    CREATED_BY  VARCHAR(200),
    CREATED_AT  TIMESTAMP_NTZ  DEFAULT CURRENT_TIMESTAMP(),
    PRIMARY KEY (NOTE_ID),
    FOREIGN KEY (TASK_ID) REFERENCES TASKS(TASK_ID)
);

"""

