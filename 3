    mc1, mc2, mc3, mc4, mc5, mc6 = st.columns(6)
    with mc1:
        st.markdown(_metric_card(total_tasks, "Total Tasks", "blue"), unsafe_allow_html=True)
    with mc2:
        st.markdown(_metric_card(in_progress, "In Progress", "teal"), unsafe_allow_html=True)
    with mc3:
        st.markdown(_metric_card(queued, "Queued", "purple"), unsafe_allow_html=True)
    with mc4:
        st.markdown(_metric_card(on_hold, "On Hold", "amber"), unsafe_allow_html=True)
    with mc5:
        st.markdown(_metric_card(closed, "Closed", "green"), unsafe_allow_html=True)
    with mc6:
        st.markdown(_metric_card(f"{float(total_effort):.1f}", "Total Effort (Days)", "red"), unsafe_allow_html=True)

    # ── Filtered Task Table ──
    st.markdown('<div class="section-label" style="margin-top:16px;">Tasks</div>', unsafe_allow_html=True)

    if ov_df.empty:
        st.info("No tasks match the selected filters.")
    else:
        display_df = ov_df.copy()

        # Add long-running flag
        def _flag_long(row):
            if row.get("STATUS") == "Closed":
                return ""
            try:
                sd = pd.to_datetime(row.get("START_DATE")).date() if not isinstance(row.get("START_DATE"), date) else row.get("START_DATE")
                return "⏱ 30+ days" if (date.today() - sd).days > 30 else ""
            except Exception:
                return ""

        display_df["FLAG"] = display_df.apply(_flag_long, axis=1)

        show_cols = ["TASK_ID", "TASK_TITLE", "OWNER", "REVIEWER", "PLATFORM_AREA", "STATUS",
                     "START_DATE", "END_DATE", "EFFORT_DAYS", "COMPLETION_PCT", "FLAG"]
        available_cols = [c for c in show_cols if c in display_df.columns]
        show_df = display_df[available_cols].copy()
        show_df.columns = [c.replace("_", " ").title() for c in show_df.columns]

        st.dataframe(show_df, use_container_width=True, hide_index=True, height=500)

    # ── Effort by Owner ──
    if not all_tasks.empty and "OWNER" in all_tasks.columns and "EFFORT_DAYS" in all_tasks.columns:
        st.markdown('<div class="section-label" style="margin-top:16px;">Effort by Owner</div>', unsafe_allow_html=True)
        effort_by_owner = all_tasks.groupby("OWNER")["EFFORT_DAYS"].sum().reset_index()
        effort_by_owner.columns = ["Owner", "Total Effort (Days)"]
        effort_by_owner = effort_by_owner.sort_values("Total Effort (Days)", ascending=False)
        st.dataframe(effort_by_owner, use_container_width=True, hide_index=True)

    # ── Tasks Not Moving ──
    if not all_tasks.empty:
        st.markdown('<div class="section-label" style="margin-top:16px;">Stale Tasks (No update in 14+ days)</div>', unsafe_allow_html=True)
        try:
            stale = all_tasks[all_tasks["STATUS"].isin(["In Progress", "Queued", "On Hold"])].copy()
            if "UPDATED_AT" in stale.columns:
                stale["UPDATED_AT"] = pd.to_datetime(stale["UPDATED_AT"])
                cutoff = datetime.now() - timedelta(days=14)
                stale = stale[stale["UPDATED_AT"] < cutoff]
            if stale.empty:
                st.info("All open tasks have been updated recently.")
            else:
                stale_show = stale[["TASK_ID", "TASK_TITLE", "OWNER", "STATUS", "UPDATED_AT"]].copy()
                stale_show.columns = ["ID", "Title", "Owner", "Status", "Last Updated"]
                st.dataframe(stale_show, use_container_width=True, hide_index=True)
        except Exception:
            st.info("Unable to determine stale tasks.")


