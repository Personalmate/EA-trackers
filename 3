def load_active_members():
    """Return list of active team member names."""
    try:
        df = session.sql("SELECT NAME FROM TEAM_MEMBERS WHERE ACTIVE_STATUS = 'Active' ORDER BY NAME").to_pandas()
        return df["NAME"].tolist() if not df.empty else []
    except Exception:
        return []


def load_all_members():
    """Return all team members as a DataFrame."""
    try:
        df = session.sql("SELECT * FROM TEAM_MEMBERS ORDER BY ACTIVE_STATUS ASC, NAME ASC").to_pandas()
        return df
    except Exception:
        return pd.DataFrame()


def load_tasks(status_filter=None, owner_filter=None, platform_filter=None,
               start_from=None, start_to=None):
    """Load tasks with optional filters."""
    try:
        where = []
        if status_filter and status_filter != "All":
            where.append(f"STATUS = '{_safe_sql(status_filter)}'")
        if owner_filter and owner_filter != "All":
            where.append(f"OWNER = '{_safe_sql(owner_filter)}'")
        if platform_filter and platform_filter != "All":
            where.append(f"PLATFORM_AREA = '{_safe_sql(platform_filter)}'")
        if start_from:
            where.append(f"START_DATE >= '{start_from}'")
        if start_to:
            where.append(f"START_DATE <= '{start_to}'")
        sql = "SELECT * FROM TASKS"
        if where:
            sql += " WHERE " + " AND ".join(where)
        sql += " ORDER BY CASE STATUS WHEN 'In Progress' THEN 1 WHEN 'Queued' THEN 2 WHEN 'On Hold' THEN 3 ELSE 4 END, UPDATED_AT DESC"
        return session.sql(sql).to_pandas()
    except Exception as e:
        st.error(f"Error loading tasks: {e}")
        return pd.DataFrame()


def load_notes_for_task(task_id):
    """Load progress notes for a given task."""
    try:
        df = session.sql(f"SELECT * FROM PROGRESS_NOTES WHERE TASK_ID = {int(task_id)} ORDER BY CREATED_AT DESC").to_pandas()
        return df
    except Exception:
        return pd.DataFrame()


def get_distinct_platforms():
    """Return distinct platform/area values from tasks."""
    try:
        df = session.sql("SELECT DISTINCT PLATFORM_AREA FROM TASKS WHERE PLATFORM_AREA IS NOT NULL AND PLATFORM_AREA != '' ORDER BY PLATFORM_AREA").to_pandas()
        return df["PLATFORM_AREA"].tolist() if not df.empty else []
    except Exception:
        return []


def get_distinct_owners():
    """Return distinct owner values from tasks."""
    try:
        df = session.sql("SELECT DISTINCT OWNER FROM TASKS ORDER BY OWNER").to_pandas()
        return df["OWNER"].tolist() if not df.empty else []
    except Exception:
        return []


def insert_member(name, role, active_status, default_reviewer, notes):
    """Insert a new team member. Returns (success, message)."""
    try:
        check = session.sql(f"SELECT COUNT(*) AS CNT FROM TEAM_MEMBERS WHERE UPPER(NAME) = UPPER('{_safe_sql(name)}')").to_pandas()
        if check["CNT"].iloc[0] > 0:
            return False, f"A team member named '{name}' already exists."
        dr = f"'{_safe_sql(default_reviewer)}'" if default_reviewer else "NULL"
        nt = f"'{_safe_sql(notes)}'" if notes else "NULL"
        session.sql(f"""
            INSERT INTO TEAM_MEMBERS (NAME, ROLE, ACTIVE_STATUS, DEFAULT_REVIEWER, NOTES)
