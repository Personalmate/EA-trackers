                    em_reviewer = st.selectbox("Default Reviewer", options=em_rev_opts, index=em_rev_opts.index(mreviewer) if mreviewer in em_rev_opts else 0, format_func=lambda x: "None" if x == "" else x, key=f"emrev_{mid}")
