        with qc3:
            q_pct = st.number_input("Completion %", min_value=0.0, max_value=100.0, value=float(pct),
                                    step=5.0, format="%.0f", key=f"qp_{task_id}")

        note_text = st.text_input("Add a note", placeholder="Type your update…", key=f"note_{task_id}")

