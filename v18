-- Fix TASK 63: Start date should be 4 Dec 2025, not 2026
UPDATE DB_CORE_PRD.BACKUP_OPS.TASKS_V2
SET START_DATE = '2025-12-04', UPDATED_AT = CURRENT_TIMESTAMP()
WHERE TASK_ID = 63;

-- Fix TASK 97: keep start, but pull closed date back to 2025
UPDATE DB_CORE_PRD.BACKUP_OPS.TASKS_V2
SET CLOSED_DATE = DATEADD(year, -1, CLOSED_DATE), UPDATED_AT = CURRENT_TIMESTAMP()
WHERE TASK_ID = 97;


SELECT TASK_ID, TITLE, BUSINESS_REASON, PLATFORM_AREA, START_DATE, CLOSED_DATE,
       STATUS, EFFORT_DAYS, COMPLETION_PCT, IMPORT_NOTES
FROM DB_CORE_PRD.BACKUP_OPS.TASKS_V2
WHERE TASK_ID IN (90, 108);


