                                index=file_cols.index(_auto("closed")) if _auto("closed") in file_cols else 0,
                                key=f"m_closed_{work_type}")

    def _g(row, col):
        if col == "-- skip --" or col not in raw.columns:
            return None
        v = row.get(col)
        if v is None or (isinstance(v, float) and pd.isna(v)):
