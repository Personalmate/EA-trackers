RE_LABEL     = re.compile(r"^\s*(why|reason|where|platform|system|how|impact|what|when)\s*[:\-]\s*(.*)$", re.IGNORECASE)
RE_NOTE_DATE = re.compile(r"^\s*(\d{1,2}[/\-](?:\d{1,2}|[A-Za-z]{3})(?:[/\-]\d{2,4})?)\s*[-:]\s*(.+)$")
RE_JIRA      = re.compile(r"\b([A-Z]{2,6}-\d+)\b")
RE_ATLAS_URL = re.compile(r"https?://\S*atlassian\.net/\S+")
MONTH_ABBR   = {m: i for i, m in enumerate(
    ["jan","feb","mar","apr","may","jun","jul","aug","sep","oct","nov","dec"], 1)}

def parse_task_description(cell):
    """Split a Task Description cell into (title, business_reason, platform_area)."""
    if cell is None or (isinstance(cell, float) and pd.isna(cell)):
        return "", "", ""
    lines = [ln.strip() for ln in str(cell).replace("\r", "").split("\n")]
    title = ""
    current = None
    buckets = {"why": [], "where": [], "how": [], "impact": [], "other": []}
    label_to_bucket = {"why":"why","reason":"why","where":"where","platform":"where",
                       "system":"where","how":"how","impact":"impact","what":"other","when":"other"}
    for ln in lines:
        if not ln:
            continue
        m = RE_LABEL.match(ln)
        if m:
            lbl = m.group(1).lower()
            current = label_to_bucket.get(lbl, "other")
            rest = m.group(2).strip()
            if rest:
                buckets[current].append(rest)
        else:
            if current is None:
                title = ln if not title else title + " " + ln
            else:
                buckets[current].append(ln)
    if not title and lines:
        title = next((l for l in lines if l), "")
    reason_parts = []
    if buckets["why"]:    reason_parts.append(" ".join(buckets["why"]))
    if buckets["how"]:    reason_parts.append("How: " + " ".join(buckets["how"]))
    if buckets["impact"]: reason_parts.append("Impact: " + " ".join(buckets["impact"]))
    if buckets["other"]:  reason_parts.append(" ".join(buckets["other"]))
    return title.strip(), " | ".join(p for p in reason_parts if p.strip()).strip(), " ".join(buckets["where"]).strip()

def parse_flexible_date(raw, fallback_year=None):
    if raw is None or (isinstance(raw, float) and pd.isna(raw)):
        return None, False
    if isinstance(raw, datetime):
        return raw.date(), False
    if isinstance(raw, date):
        return raw, False
    s = str(raw).strip()
    if not s or s.upper() in ("NA","N/A","TBD","PENDING","ONGOING"):
        return None, False
    # DD/MMM/YYYY or DD-MMM-YY
    m = re.match(r"^(\d{1,2})[/\-]([A-Za-z]{3})(?:[/\-](\d{2,4}))?$", s)
    if m:
        d = int(m.group(1)); mo = MONTH_ABBR.get(m.group(2).lower()); y = m.group(3)
        if mo:
            if y:
                y = int(y); y = 2000 + y if y < 100 else y
            else:
                y = fallback_year or date.today().year
            try:
                return date(y, mo, d), False
            except ValueError:
                return None, False
    # DD/MM no year
    m = re.match(r"^(\d{1,2})[/\-](\d{1,2})$", s)
    if m:
        d = int(m.group(1)); mo = int(m.group(2))
        y = fallback_year or date.today().year
        try:
            return date(y, mo, d), False
        except ValueError:
            return None, False
    # DD/MM/YYYY or MM/DD/YYYY -- ambiguous if both parts <=12 and !=
    m = re.match(r"^(\d{1,2})[/\-](\d{1,2})[/\-](\d{2,4})$", s)
    if m:
        a, b, y = int(m.group(1)), int(m.group(2)), int(m.group(3))
        y = 2000 + y if y < 100 else y
        ambiguous = (a <= 12 and b <= 12 and a != b)
        # default day-first (AU/UK convention)
        try:
            return date(y, b, a), ambiguous
        except ValueError:
            try:
                return date(y, a, b), ambiguous
            except ValueError:
                return None, False
    # fallback to pandas
    try:
        dt = pd.to_datetime(s, dayfirst=True, errors="coerce")
        if pd.notna(dt):
            return dt.date(), False
    except Exception:
        pass
    return None, False

def parse_status_update(cell, row_start_date=None):
    if cell is None or (isinstance(cell, float) and pd.isna(cell)):
        return []
    year_hint = row_start_date.year if row_start_date else None
    out = []
    for ln in str(cell).replace("\r","").split("\n"):
        ln = ln.strip()
        if not ln:
            continue
        m = RE_NOTE_DATE.match(ln)
        if m:
            raw_date, text = m.group(1), m.group(2).strip()
            parsed, _ = parse_flexible_date(raw_date, fallback_year=year_hint)
            out.append((parsed, text))
        else:
            out.append((None, ln))
    return out

def parse_assignees(cell):
    if cell is None or (isinstance(cell, float) and pd.isna(cell)):
        return None, None, None, []
    parts = [p.strip() for p in re.split(r"[/\\&,;]|\s+and\s+", str(cell)) if p.strip()]
    canon = [canonical_name(p) for p in parts]
    canon = [c for c in canon if c]
    return (canon[0] if len(canon) >= 1 else None,
            canon[1] if len(canon) >= 2 else None,
            canon[2] if len(canon) >= 3 else None,
            canon[3:] if len(canon) > 3 else [])

def extract_jira(*texts):
    for t in texts:
        if t is None or (isinstance(t, float) and pd.isna(t)):
            continue
        s = str(t)
        m = RE_JIRA.search(s)
        if m:
            return m.group(1)
        m = RE_ATLAS_URL.search(s)
        if m:
            return m.group(0)
    return None

def map_status(raw):
    if raw is None or (isinstance(raw, float) and pd.isna(raw)):
        return "Queued", "status missing"
    s = str(raw).strip()
    if not s:
        return "Queued", "status blank"
    for canon in STATUS_OPTIONS:
        if s.lower() == canon.lower():
            return canon, None
    if "pending" in s.lower():
        return "On Hold", f"status was: {s}"
    return "Queued", f"unrecognised status: {s}"


