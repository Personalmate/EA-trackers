def _esc(v):
    return "" if v is None else _html.escape(str(v))

def _safe_sql(v):
    return "" if v is None else str(v).replace("'", "''")

def _sql_str(v):
    if v is None or (isinstance(v, float) and pd.isna(v)) or str(v).strip() == "":
        return "NULL"
    return f"'{_safe_sql(v)}'"

def _sql_date(v):
    if v is None or (isinstance(v, float) and pd.isna(v)):
        return "NULL"
    if isinstance(v, datetime):
        return f"'{v.strftime('%Y-%m-%d')}'"
    if isinstance(v, date):
        return f"'{v.strftime('%Y-%m-%d')}'"
    return f"'{_safe_sql(v)}'"

def _sql_num(v, default=0):
    try:
        f = float(v)
        if pd.isna(f): return str(default)
        return str(f)
    except Exception:
        return str(default)

def _status_badge(s):
    cls = {"Queued":"status-queued","In Progress":"status-inprogress","On Hold":"status-onhold",
           "Closed":"status-closed","Cancelled":"status-cancelled"}.get(s, "status-queued")
    return f'<span class="status-badge {cls}">{_esc(s)}</span>'

def _metric_card(value, label, color="blue"):
    return f'<div class="metric-card mc-{color}"><p class="metric-value">{_esc(value)}</p><p class="metric-label">{_esc(label)}</p></div>'

def _progress_html(pct):
    pct = max(0, min(100, float(pct or 0)))
    color = "#22c55e" if pct >= 100 else "#3b82f6" if pct >= 60 else "#f59e0b" if pct >= 30 else "#ef4444"
    return f'<div class="progress-outer"><div class="progress-inner" style="width:{pct}%;background:{color};"></div></div>'


