-- Tasks with start dates in the future
SELECT TASK_ID, WORK_TYPE, TITLE, START_DATE, CLOSED_DATE, STATUS
FROM DB_CORE_PRD.BACKUP_OPS.TASKS_V2
WHERE START_DATE > CURRENT_DATE() OR CLOSED_DATE > CURRENT_DATE()
ORDER BY GREATEST(COALESCE(START_DATE,'1900-01-01'), COALESCE(CLOSED_DATE,'1900-01-01')) DESC;
