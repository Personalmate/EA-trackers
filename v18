def insert_task(work_type, title, reason, platform, reviewer_id, start_dt, closed_dt,
                status, effort, pct, jira, overflow, import_notes, created_by_id,
                primary_id, secondary_id, tertiary_id):
    try:
        rev = "NULL" if reviewer_id is None else str(int(reviewer_id))
        cb  = "NULL" if created_by_id is None else str(int(created_by_id))
        session.sql(f"""
            INSERT INTO {TBL_TASKS}
              (WORK_TYPE, TITLE, BUSINESS_REASON, PLATFORM_AREA, REVIEWER_MEMBER_ID,
               START_DATE, CLOSED_DATE, STATUS, EFFORT_DAYS, COMPLETION_PCT,
               JIRA_REFERENCE, OVERFLOW_ASSIGNEES, IMPORT_NOTES, CREATED_BY_MEMBER_ID)
            SELECT '{_safe_sql(work_type)}', '{_safe_sql(title)}', {_sql_str(reason)},
                   {_sql_str(platform)}, {rev}, {_sql_date(start_dt)}, {_sql_date(closed_dt)},
                   '{_safe_sql(status)}', {_sql_num(effort)}, {_sql_num(pct)},
                   {_sql_str(jira)}, {_sql_str(overflow)}, {_sql_str(import_notes)}, {cb}
        """).collect()
        tid = int(session.sql(f"SELECT MAX(TASK_ID) AS T FROM {TBL_TASKS}").to_pandas()["T"].iloc[0])
        for role, mid in [("primary", primary_id), ("secondary", secondary_id), ("tertiary", tertiary_id)]:
            if mid is None:
                continue
            session.sql(
                f"INSERT INTO {TBL_ASSIGN} (TASK_ID, MEMBER_ID, ASSIGNEE_ROLE) "
                f"VALUES ({tid}, {int(mid)}, '{role}')"
            ).collect()
        return True, tid
    except Exception as e:
        return False, str(e)

def update_task_row(task_id, title, reason, platform, reviewer_id, start_dt, closed_dt,
                    status, effort, pct, jira, primary_id, secondary_id, tertiary_id):
    try:
        rev = "NULL" if reviewer_id is None else str(int(reviewer_id))
        session.sql(f"""
            UPDATE {TBL_TASKS} SET
                TITLE = '{_safe_sql(title)}',
                BUSINESS_REASON = {_sql_str(reason)},
                PLATFORM_AREA = {_sql_str(platform)},
                REVIEWER_MEMBER_ID = {rev},
                START_DATE = {_sql_date(start_dt)},
                CLOSED_DATE = {_sql_date(closed_dt)},
                STATUS = '{_safe_sql(status)}',
                EFFORT_DAYS = {_sql_num(effort)},
                COMPLETION_PCT = {_sql_num(pct)},
                JIRA_REFERENCE = {_sql_str(jira)},
                UPDATED_AT = CURRENT_TIMESTAMP()
            WHERE TASK_ID = {int(task_id)}
        """).collect()
        session.sql(f"DELETE FROM {TBL_ASSIGN} WHERE TASK_ID = {int(task_id)}").collect()
        for role, mid in [("primary", primary_id), ("secondary", secondary_id), ("tertiary", tertiary_id)]:
            if mid is None:
                continue
            session.sql(
                f"INSERT INTO {TBL_ASSIGN} (TASK_ID, MEMBER_ID, ASSIGNEE_ROLE) "
                f"VALUES ({int(task_id)}, {int(mid)}, '{role}')"
            ).collect()
        return True, None
    except Exception as e:
        return False, str(e)

