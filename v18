        if reason:
            st.markdown(f'<div class="task-meta-item"><strong>Why:</strong> {_esc(reason)}</div>', unsafe_allow_html=True)
        if overflow:
            st.markdown(f'<div class="warning-box">Extra assignees (beyond 3): {_esc(overflow)}</div>', unsafe_allow_html=True)
