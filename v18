                rev_parts = [p.strip() for p in re.split(r"[/\\&,;]|\s+and\s+", str(rev_raw)) if p.strip()]
                rev_list = [canonical_name(p) for p in rev_parts if canonical_name(p)]
            reviewer = rev_list[0] if rev_list else None
            if len(rev_list) > 1:
                flags.append(f"extra reviewers: {', '.join(rev_list[1:])}")

            sd_raw = _g(row, m_start)
            start_dt, sd_amb = parse_flexible_date(sd_raw)
            if sd_raw and not start_dt:
                flags.append(f"start date unparseable: {sd_raw}")
            elif sd_amb:
                flags.append(f"start date ambiguous: {sd_raw}")

            cd_raw = _g(row, m_closed)
            closed_dt, cd_amb = parse_flexible_date(cd_raw, fallback_year=(start_dt.year if start_dt else None))
            if cd_raw and not closed_dt:
                flags.append(f"closed date unparseable: {cd_raw}")
            elif cd_amb:
                flags.append(f"closed date ambiguous: {cd_raw}")

            status, status_flag = map_status(_g(row, m_status))
            if status_flag:
                flags.append(status_flag)
            if status == "Closed" and not closed_dt:
                flags.append("closed but no closed_date")

            try:
                effort = float(_g(row, m_eff) or 0)
                if pd.isna(effort): effort = 0
            except Exception:
                effort = 0
                if _g(row, m_eff) is not None:
                    flags.append("effort non-numeric")

            try:
                pct = float(_g(row, m_pct) or 0)
                if pd.isna(pct): pct = 0
            except Exception:
                pct = 0
                if _g(row, m_pct) is not None:
                    flags.append("pct non-numeric")
            pct = max(0.0, min(100.0, pct))

            jira = _g(row, m_jira)
            if not jira:
                jira = extract_jira(_g(row, m_title), _g(row, m_upd))

            notes = parse_status_update(_g(row, m_upd), row_start_date=start_dt)
            total_notes += len(notes)

            preview.append({
                "_row": idx + 2,  # excel row number (header is row 1)
                "work_type": work_type,
                "title": title,
                "business_reason": reason,
                "platform_area": platform,
                "primary_assignee": primary,
                "secondary_assignee": secondary,
                "tertiary_assignee": tertiary,
                "overflow_assignees": ", ".join(overflow) if overflow else "",
                "reviewer": reviewer,
                "start_date": start_dt,
                "closed_date": closed_dt,
                "status": status,
                "effort_days": effort,
                "completion_pct": pct,
                "jira_reference": jira,
                "import_notes": " | ".join(flags),
                "_notes": notes,
            })

        pv_df = pd.DataFrame(preview)
        st.session_state["import_preview"][work_type] = pv_df
        st.session_state[f"import_notes_total_{work_type}"] = total_notes

    pv_df = st.session_state["import_preview"].get(work_type)
    if pv_df is None or pv_df.empty:
        return

    notes_total = st.session_state.get(f"import_notes_total_{work_type}", 0)
    flagged = pv_df[pv_df["import_notes"] != ""]
    ready   = pv_df[(pv_df["title"] != "") & (pv_df["primary_assignee"].notna()) & (pv_df["primary_assignee"] != "")]
    blocked = pv_df[(pv_df["title"] == "") | (pv_df["primary_assignee"].isna()) | (pv_df["primary_assignee"] == "")]

    mcol1, mcol2, mcol3, mcol4 = st.columns(4)
    with mcol1: st.markdown(_metric_card(len(pv_df), "Rows parsed", "blue"), unsafe_allow_html=True)
    with mcol2: st.markdown(_metric_card(len(ready), "Ready to import", "green"), unsafe_allow_html=True)
    with mcol3: st.markdown(_metric_card(len(blocked), "Will be skipped", "red"), unsafe_allow_html=True)
    with mcol4: st.markdown(_metric_card(notes_total, "Notes to create", "purple"), unsafe_allow_html=True)

    if len(flagged) > 0:
        st.markdown(
            f'<div class="warning-box">{len(flagged)} row(s) have flags. '
            f'They will still import (unless missing title or primary assignee) — '
            f'check IMPORT_NOTES in the app after.</div>',
            unsafe_allow_html=True)

    show_cols = ["_row","title","primary_assignee","secondary_assignee","tertiary_assignee",
                 "overflow_assignees","reviewer","start_date","closed_date","status",
                 "effort_days","completion_pct","jira_reference","import_notes"]
    st.dataframe(pv_df[show_cols].head(30), use_container_width=True, hide_index=True)
    if len(pv_df) > 30:
        st.caption(f"Showing first 30 of {len(pv_df)}")

    col_imp, col_cancel = st.columns(2)
    with col_imp:
        if st.button(f"Import {len(ready)} row(s) into {work_type}", type="primary",
                     use_container_width=True, key=f"doimport_{work_type}"):
            ok_count = 0; fail_count = 0; fail_msgs = []
            prog = st.progress(0)
            for i, (_, r) in enumerate(ready.iterrows()):
                primary_id   = resolve_member_id(r["primary_assignee"], members_df)
                secondary_id = resolve_member_id(r["secondary_assignee"], members_df) if r["secondary_assignee"] else None
                tertiary_id  = resolve_member_id(r["tertiary_assignee"], members_df)  if r["tertiary_assignee"]  else None
                reviewer_id  = resolve_member_id(r["reviewer"], members_df) if r["reviewer"] else None
                if primary_id is None:
                    fail_count += 1
                    fail_msgs.append(f"Row {r['_row']}: primary assignee '{r['primary_assignee']}' not in TEAM_MEMBERS")
                    continue
                ok, res = insert_task(
                    work_type, r["title"], r["business_reason"], r["platform_area"], reviewer_id,
                    r["start_date"], r["closed_date"], r["status"], r["effort_days"], r["completion_pct"],
                    r["jira_reference"], r["overflow_assignees"], r["import_notes"], current_member_id,
                    primary_id, secondary_id, tertiary_id,
                )
                if ok:
                    ok_count += 1
                    task_id = res
                    for note_date, note_text in r["_notes"]:
                        insert_note(task_id, note_text, None, note_date=note_date, is_imported=True)
                else:
                    fail_count += 1
                    fail_msgs.append(f"Row {r['_row']}: {res}")
                prog.progress((i + 1) / max(len(ready), 1))
            prog.empty()
            if ok_count:
                st.markdown(f'<div class="success-box">Imported {ok_count} task(s).</div>', unsafe_allow_html=True)
            if fail_count:
                st.markdown(f'<div class="error-box">{fail_count} row(s) failed.</div>', unsafe_allow_html=True)
                for fm in fail_msgs[:10]:
                    st.caption(fm)
                if len(fail_msgs) > 10:
                    st.caption(f"...and {len(fail_msgs) - 10} more")
            st.session_state["import_preview"][work_type] = None
    with col_cancel:
        if st.button("Cancel / clear preview", use_container_width=True, key=f"cancel_{work_type}"):
            st.session_state["import_preview"][work_type] = None
            st.rerun()


