def render_import_section(work_type):
    st.markdown(f"""<div class="warning-box">
        Upload your Excel workbook and pick the sheet that matches <strong>{work_type}</strong>.
        The app parses Task Description into Title / Why / Where, splits multi-assignee on '/',
        converts Status Update lines into individual notes, and maps name variants
        (Harry→Harrison, Yesh→Yeshwenth, AIko→Aiko, Batch Team→Aiko, Benjamin→Ben, POppy→Poppy).
        Flagged rows (ambiguous dates, 4+ assignees, unknown status) are imported with
        IMPORT_NOTES so you can fix them in-app.
    </div>""", unsafe_allow_html=True)

    uploaded = st.file_uploader(f"Upload file for {work_type}",
                                type=["xlsx","xls","csv"], key=f"up_{work_type}")
    if uploaded is None:
        return

    fname = uploaded.name.lower()
    is_csv = fname.endswith(".csv")

    if is_csv:
        # CSV path — no openpyxl needed; try utf-8 first, fall back to cp1252/latin1
        try:
            raw = pd.read_csv(uploaded, encoding="utf-8")
        except UnicodeDecodeError:
            uploaded.seek(0)
            raw = pd.read_csv(uploaded, encoding="cp1252")
        except Exception as e:
            st.error(f"Cannot read CSV: {e}")
            return
        sheet = "(CSV — single sheet)"
    else:
        # Excel path — needs openpyxl
        try:
            xl = pd.ExcelFile(uploaded, engine="openpyxl")
        except ImportError:
            st.error(
                "**openpyxl is not installed.** In the Streamlit editor, click the "
                "**Packages** dropdown (top-right), search for **openpyxl**, add it, "
                "then re-run. Or save your file as **.csv** and upload that instead."
            )
            return
        except Exception as e:
            st.error(f"Cannot read file: {e}")
            return

        default_sheet = work_type + "s"  # "Enhancements" / "Automations"
        if default_sheet not in xl.sheet_names:
            default_sheet = xl.sheet_names[0]
