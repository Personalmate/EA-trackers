def resolve_member_id(name, members_df):
    if not name or members_df.empty:
        return None
    canon = canonical_name(name)
    if not canon:
        return None
    m = members_df[members_df["FULL_NAME"].str.lower() == canon.lower()]
    return int(m["MEMBER_ID"].iloc[0]) if not m.empty else None

