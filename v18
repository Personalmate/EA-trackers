def render_task_card(row, assignees, work_type):
    task_id   = int(row["TASK_ID"])
    title     = row.get("TITLE") or ""
    status    = row.get("STATUS") or "Queued"
    pct       = float(row.get("COMPLETION_PCT") or 0)
    effort    = float(row.get("EFFORT_DAYS") or 0)
    start_dt  = row.get("START_DATE")
    closed_dt = row.get("CLOSED_DATE")
    reviewer  = row.get("REVIEWER_NAME") or ""
    platform  = row.get("PLATFORM_AREA") or ""
    reason    = row.get("BUSINESS_REASON") or ""
    jira      = row.get("JIRA_REFERENCE") or ""
    overflow  = row.get("OVERFLOW_ASSIGNEES") or ""
    import_notes = row.get("IMPORT_NOTES") or ""

    role_order = {"primary": 0, "secondary": 1, "tertiary": 2}
    a_sorted = sorted(assignees, key=lambda a: role_order.get(a[0], 9))
    primary_name   = a_sorted[0][1] if len(a_sorted) >= 1 else ""
    secondary_name = a_sorted[1][1] if len(a_sorted) >= 2 else ""
    tertiary_name  = a_sorted[2][1] if len(a_sorted) >= 3 else ""
    assignee_str = " / ".join([n for _, n in a_sorted]) or "—"

    label = f"{title}   |   {primary_name or '—'}   |   {status}   |   {int(pct)}%   |   {effort:.1f}d"
    with st.expander(label, expanded=False):
        st.markdown(f"""<div class="task-meta">
            <div class="task-meta-item"><strong>Assignees:</strong> {_esc(assignee_str)}</div>
            <div class="task-meta-item"><strong>Reviewer:</strong> {_esc(reviewer) or '—'}</div>
            <div class="task-meta-item"><strong>Platform:</strong> {_esc(platform) or '—'}</div>
            <div class="task-meta-item"><strong>Start:</strong> {_esc(start_dt) or '—'}</div>
            <div class="task-meta-item"><strong>Closed:</strong> {_esc(closed_dt) or '—'}</div>
            <div class="task-meta-item"><strong>JIRA:</strong> {_esc(jira) or '—'}</div>
