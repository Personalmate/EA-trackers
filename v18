    st.markdown(f'<div class="section-label">File preview ({len(raw)} rows, {len(raw.columns)} cols)</div>', unsafe_allow_html=True)
    st.dataframe(raw.head(5), use_container_width=True, hide_index=True)

    # --- Column mapping ---
    st.markdown('<div class="section-label">Column Mapping</div>', unsafe_allow_html=True)

    file_cols = ["-- skip --"] + list(raw.columns.astype(str))
    def _auto(needle):
        for c in raw.columns:
            if str(c).lower().strip() == needle:
                return str(c)
        for c in raw.columns:
            if needle in str(c).lower():
                return str(c)
        return "-- skip --"

    mc1, mc2 = st.columns(2)
