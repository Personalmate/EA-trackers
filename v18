def load_tasks(work_type, status_filter=None, assignee_member_id=None, search=None, sort_by=None):
    try:
        where = [f"t.WORK_TYPE = '{_safe_sql(work_type)}'"]
        if status_filter and status_filter != "All":
            where.append(f"t.STATUS = '{_safe_sql(status_filter)}'")
        if assignee_member_id:
            where.append(f"t.TASK_ID IN (SELECT TASK_ID FROM {TBL_ASSIGN} WHERE MEMBER_ID={int(assignee_member_id)})")
        if search and search.strip():
            s = _safe_sql(search.strip().lower())
            where.append(
                "(LOWER(COALESCE(t.TITLE,'')) LIKE '%{s}%' "
                "OR LOWER(COALESCE(t.BUSINESS_REASON,'')) LIKE '%{s}%' "
                "OR LOWER(COALESCE(t.PLATFORM_AREA,'')) LIKE '%{s}%' "
                "OR LOWER(COALESCE(t.JIRA_REFERENCE,'')) LIKE '%{s}%')".format(s=s)
            )
        order_clause = SORT_OPTIONS.get(sort_by or "", SORT_OPTIONS["Status then recent update"])
        sql = f"""
            SELECT t.*, r.FULL_NAME AS REVIEWER_NAME
            FROM {TBL_TASKS} t
            LEFT JOIN {TBL_MEMBERS} r ON r.MEMBER_ID = t.REVIEWER_MEMBER_ID
            WHERE {' AND '.join(where)}
            ORDER BY {order_clause}
        """
        return session.sql(sql).to_pandas()
    except Exception as e:
        st.error(f"Error loading tasks: {e}")
        return pd.DataFrame()

