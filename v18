            st.markdown(f'<div class="warning-box">Import flags: {_esc(import_notes)}</div>', unsafe_allow_html=True)

        st.markdown(_progress_html(pct), unsafe_allow_html=True)

        # Quick update
        qc1, qc2, qc3 = st.columns(3)
        with qc1:
            q_status = st.selectbox("Status", STATUS_OPTIONS,
