                                index=file_cols.index(_auto("effort")) if _auto("effort") in file_cols else 0,
                                key=f"m_eff_{work_type}")
    with mc2:
        m_status = st.selectbox("Status *", file_cols,
                                index=file_cols.index(_auto("status")) if _auto("status") in file_cols and "update" not in _auto("status") else 0,
                                key=f"m_status_{work_type}")
