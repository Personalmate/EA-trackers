                st.markdown(
                    f'<div class="note-card"><div class="note-meta">{_esc(by)} · {_esc(nd)}</div>'
                    f'<div class="note-text">{_esc(n.get("NOTE_TEXT",""))}</div></div>',
                    unsafe_allow_html=True)
