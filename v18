# WORK-TYPE PAGE RENDERER (Enhancements / Automation)
# ============================================================
def render_work_type_page(work_type):
    # Add new task
    st.markdown(f'<div class="section-label">Add new {work_type} task</div>', unsafe_allow_html=True)
    with st.form(f"add_form_{work_type}", clear_on_submit=True):
        c1, c2 = st.columns(2)
        names = [""] + members_df["FULL_NAME"].tolist()
        with c1:
            title    = st.text_input("Task Title *", key=f"nt_title_{work_type}")
            reason   = st.text_area("Business Reason (Why)", height=80, key=f"nt_reason_{work_type}")
            platform = st.text_input("Platform / Area (Where)", key=f"nt_plat_{work_type}")
            primary   = st.selectbox("Primary Assignee *", names, key=f"nt_p_{work_type}")
            secondary = st.selectbox("Secondary Assignee",  names, key=f"nt_s_{work_type}")
            tertiary  = st.selectbox("Tertiary Assignee",   names, key=f"nt_t_{work_type}")
            reviewer  = st.selectbox("Reviewer", names, key=f"nt_r_{work_type}")
        with c2:
            start_dt  = st.date_input("Start Date *", value=date.today(), key=f"nt_sd_{work_type}")
            closed_dt = st.date_input("Closed Date", value=None, key=f"nt_cd_{work_type}")
            status    = st.selectbox("Status", STATUS_OPTIONS, key=f"nt_st_{work_type}")
            effort    = st.number_input("Effort (Days)", min_value=0.0, value=0.0, step=0.5, key=f"nt_ef_{work_type}")
            pct       = st.number_input("Completion %", min_value=0.0, max_value=100.0, value=0.0, step=5.0, key=f"nt_pc_{work_type}")
            jira      = st.text_input("JIRA / Reference", key=f"nt_jr_{work_type}")

        if st.form_submit_button(f"Create {work_type} task", type="primary", use_container_width=True):
            errs = []
            if not title.strip(): errs.append("Title required")
            if not primary: errs.append("Primary assignee required")
            if status == "Closed" and not closed_dt: errs.append("Closed Date required when status Closed")
            if closed_dt and closed_dt < start_dt: errs.append("Closed Date cannot precede Start Date")
            if pct == 100 and status not in ("Closed","Cancelled"): errs.append("100% requires Closed or Cancelled")
            if errs:
                for e in errs: st.error(e)
            else:
                ok, msg = insert_task(
                    work_type, title.strip(), reason, platform,
                    resolve_member_id(reviewer, members_df) if reviewer else None,
                    start_dt, closed_dt, status, effort, pct, jira, None, None, current_member_id,
                    resolve_member_id(primary, members_df),
                    resolve_member_id(secondary, members_df) if secondary else None,
                    resolve_member_id(tertiary, members_df)  if tertiary  else None,
                )
                if ok:
                    st.session_state["success_message"] = f"{work_type} task created."
                    st.rerun()
                else:
                    st.error(msg)

    # Filters
    st.markdown('<div class="section-label" style="margin-top:14px;">Existing tasks</div>', unsafe_allow_html=True)
    fc1, fc2, fc3, fc4 = st.columns([1,1,1.2,1.4])
    with fc1:
        status_f = st.selectbox("Status", ["All"] + STATUS_OPTIONS, key=f"sf_{work_type}")
    with fc2:
        assignee_name = st.selectbox("Assignee", ["All"] + members_df["FULL_NAME"].tolist(), key=f"af_{work_type}")
    with fc3:
        sort_by = st.selectbox("Sort by", list(SORT_OPTIONS.keys()), key=f"sort_{work_type}")
    with fc4:
        search = st.text_input("Search (title / reason / platform / JIRA)", key=f"srch_{work_type}")

    # Quick filter chips
    qc1, qc2, qc3, qc4 = st.columns(4)
    quick = st.session_state.get(f"quick_{work_type}", None)
    with qc1:
        if st.button("Open only", key=f"q_open_{work_type}", use_container_width=True):
            st.session_state[f"quick_{work_type}"] = "open"; st.rerun()
    with qc2:
        if st.button("Mine", key=f"q_mine_{work_type}", use_container_width=True):
            st.session_state[f"quick_{work_type}"] = "mine"; st.rerun()
    with qc3:
        if st.button("Stale >30d", key=f"q_stale_{work_type}", use_container_width=True):
            st.session_state[f"quick_{work_type}"] = "stale"; st.rerun()
    with qc4:
        if st.button("Clear quick filter", key=f"q_clr_{work_type}", use_container_width=True):
            st.session_state[f"quick_{work_type}"] = None; st.rerun()
    if quick:
        st.caption(f"Quick filter active: **{quick}**")

    assignee_id = resolve_member_id(assignee_name, members_df) if assignee_name != "All" else None
    tasks_df = load_tasks(work_type, status_filter=status_f, assignee_member_id=assignee_id, search=search, sort_by=sort_by)

    # Apply quick filters post-query
    if not tasks_df.empty and quick:
        if quick == "open":
            tasks_df = tasks_df[tasks_df["STATUS"].isin(OPEN_STATUSES)]
        elif quick == "mine" and current_member_id:
            try:
                mine_ids = session.sql(
                    f"SELECT TASK_ID FROM {TBL_ASSIGN} WHERE MEMBER_ID={int(current_member_id)}"
                ).to_pandas()["TASK_ID"].tolist()
                tasks_df = tasks_df[tasks_df["TASK_ID"].isin(mine_ids)]
            except Exception as e:
                st.caption(f"Could not apply 'Mine' filter: {e}")
        elif quick == "stale":
            today = date.today()
            def _is_stale(r):
                if r["STATUS"] not in OPEN_STATUSES: return False
                try: sd = pd.to_datetime(r["START_DATE"]).date()
                except Exception: return False
                return (today - sd).days > 30
            tasks_df = tasks_df[tasks_df.apply(_is_stale, axis=1)]

    if tasks_df.empty:
        st.info(f"No {work_type.lower()} tasks match filters.")
    else:
        a_df = load_assignees_for(tasks_df["TASK_ID"].tolist())
        by_tid = {}
        for _, ar in a_df.iterrows():
            by_tid.setdefault(int(ar["TASK_ID"]), []).append((ar["ASSIGNEE_ROLE"], ar["FULL_NAME"]))
        st.markdown(f'<p class="note-meta">{len(tasks_df)} task(s)</p>', unsafe_allow_html=True)
        for _, row in tasks_df.iterrows():
            render_task_card(row, by_tid.get(int(row["TASK_ID"]), []), work_type)

    render_edit_panel(work_type)

    st.markdown("---")
    st.markdown(f'<div class="section-label">Import {work_type} data from Excel</div>', unsafe_allow_html=True)
    render_import_section(work_type)


# ============================================================
# STATS PAGE
# ============================================================
def render_stats_page():
    tasks = load_all_tasks()
    if tasks.empty:
        st.info("No tasks yet. Create some or import.")
        return

    assigns = load_all_assignees()

    total_tasks = len(tasks)
    open_tasks  = len(tasks[tasks["STATUS"].isin(OPEN_STATUSES)])
    in_progress = len(tasks[tasks["STATUS"] == "In Progress"])
    on_hold     = len(tasks[tasks["STATUS"] == "On Hold"])
    closed_all  = len(tasks[tasks["STATUS"] == "Closed"])
    total_effort = float(pd.to_numeric(tasks["EFFORT_DAYS"], errors="coerce").fillna(0).sum())

    today = date.today()
    month_start = today.replace(day=1)
    def _to_date(x):
        if x is None or (isinstance(x, float) and pd.isna(x)): return None
        if isinstance(x, date) and not isinstance(x, datetime): return x
        try: return pd.to_datetime(x).date()
        except Exception: return None

    tasks["_CLOSED"] = tasks["CLOSED_DATE"].apply(_to_date)
    closed_this_month = len(tasks[(tasks["STATUS"] == "Closed") &
                                  (tasks["_CLOSED"].apply(lambda d: d is not None and d >= month_start))])

    # Long running open tasks (>30 days)
    tasks["_START"] = tasks["START_DATE"].apply(_to_date)
    long_open = len(tasks[(tasks["STATUS"].isin(OPEN_STATUSES)) &
                          (tasks["_START"].apply(lambda d: d is not None and (today - d).days > 30))])

    st.markdown('<div class="section-label">Key metrics</div>', unsafe_allow_html=True)
    m1, m2, m3, m4, m5, m6 = st.columns(6)
    with m1: st.markdown(_metric_card(total_tasks, "Total tasks", "blue"), unsafe_allow_html=True)
    with m2: st.markdown(_metric_card(open_tasks,  "Open", "teal"), unsafe_allow_html=True)
    with m3: st.markdown(_metric_card(in_progress, "In progress", "purple"), unsafe_allow_html=True)
    with m4: st.markdown(_metric_card(closed_this_month, "Closed this month", "green"), unsafe_allow_html=True)
    with m5: st.markdown(_metric_card(f"{total_effort:.0f}", "Effort days logged", "amber"), unsafe_allow_html=True)
    with m6: st.markdown(_metric_card(long_open, "Open >30 days", "red"), unsafe_allow_html=True)

    st.markdown('<div class="section-label" style="margin-top:16px;">Charts</div>', unsafe_allow_html=True)

    # Chart 1 & 2
    ch1, ch2 = st.columns(2)

    # Chart 1: Status distribution (all tasks, stacked by work_type)
    with ch1:
        st.markdown("**Status distribution (by work type)**")
        try:
            piv = tasks.pivot_table(index="STATUS", columns="WORK_TYPE",
                                    values="TASK_ID", aggfunc="count", fill_value=0)
            piv = piv.reindex(STATUS_OPTIONS).fillna(0)
            # Ensure both work-type columns always present for stable color mapping
            for wt in ["Enhancement","Automation"]:
                if wt not in piv.columns: piv[wt] = 0
            piv = piv[["Enhancement","Automation"]]
            st.bar_chart(piv, horizontal=True, stack=True,
                         color=["#3b82f6","#14b8a6"], height=320)
        except Exception as e:
            st.caption(f"Chart error: {e}")

    # Chart 2: Effort by primary assignee (top 10)
    with ch2:
        st.markdown("**Effort days by primary assignee (top 10)**")
        try:
            primary = assigns[assigns["ASSIGNEE_ROLE"] == "primary"].merge(
                tasks[["TASK_ID","EFFORT_DAYS"]], on="TASK_ID", how="left")
            primary["EFFORT_DAYS"] = pd.to_numeric(primary["EFFORT_DAYS"], errors="coerce").fillna(0)
            grp = primary.groupby("FULL_NAME")["EFFORT_DAYS"].sum().sort_values(ascending=True).tail(10)
            df = grp.reset_index()
            df.columns = ["Person", "Effort (Days)"]
            if df.empty:
                st.info("No effort data yet.")
            else:
                st.bar_chart(df.set_index("Person"), horizontal=True,
                             color="#3b82f6", height=320)
        except Exception as e:
            st.caption(f"Chart error: {e}")

    # Chart 3 & 4
    ch3, ch4 = st.columns(2)

    # Chart 3: Open tasks per person (stacked by status)
    with ch3:
        st.markdown("**Open tasks per primary assignee**")
        try:
            primary = assigns[assigns["ASSIGNEE_ROLE"] == "primary"].merge(
                tasks[["TASK_ID","STATUS"]], on="TASK_ID", how="left")
            open_df = primary[primary["STATUS"].isin(OPEN_STATUSES)]
            if not open_df.empty:
                piv = open_df.pivot_table(index="FULL_NAME", columns="STATUS",
                                          values="TASK_ID", aggfunc="count", fill_value=0)
                for s in OPEN_STATUSES:
                    if s not in piv.columns:
                        piv[s] = 0
                piv = piv[OPEN_STATUSES].sort_values(OPEN_STATUSES, ascending=True)
                st.bar_chart(piv, horizontal=True, stack=True,
                             color=["#60a5fa","#a78bfa","#fbbf24"], height=320)
            else:
                st.info("No open tasks.")
        except Exception as e:
            st.caption(f"Chart error: {e}")

    # Chart 4: Monthly closure throughput (last 6 months)
    with ch4:
        st.markdown("**Closed tasks per month (last 6 months)**")
        try:
            closed_df = tasks[(tasks["STATUS"] == "Closed") & (tasks["_CLOSED"].notna())].copy()
            if not closed_df.empty:
                closed_df["_MONTH"] = closed_df["_CLOSED"].apply(lambda d: d.replace(day=1))
                cutoff = (today.replace(day=1) - pd.DateOffset(months=5)).date()
                closed_df = closed_df[closed_df["_MONTH"] >= cutoff]
                by_month = closed_df.groupby(["_MONTH","WORK_TYPE"])["TASK_ID"].count().unstack(fill_value=0)
                for wt in ["Enhancement","Automation"]:
                    if wt not in by_month.columns: by_month[wt] = 0
                by_month = by_month[["Enhancement","Automation"]].sort_index()
                by_month.index = [d.strftime("%b %Y") for d in by_month.index]
                st.bar_chart(by_month, color=["#3b82f6","#14b8a6"],
                             stack=True, height=320)
            else:
                st.info("No closed tasks yet.")
        except Exception as e:
            st.caption(f"Chart error: {e}")


# ============================================================
# DANGER ZONE — reset all task data
# ============================================================
def render_danger_zone():
    st.markdown("---")
    with st.expander("Danger Zone — reset all task data", expanded=False):
        st.warning(
            "This will permanently delete **all tasks, all assignees, and all "
            "progress notes**. TEAM_MEMBERS is preserved. This cannot be undone."
        )
        try:
            cnt_t = session.sql(f"SELECT COUNT(*) C FROM {TBL_TASKS}").to_pandas().iloc[0]["C"]
            cnt_a = session.sql(f"SELECT COUNT(*) C FROM {TBL_ASSIGN}").to_pandas().iloc[0]["C"]
            cnt_n = session.sql(f"SELECT COUNT(*) C FROM {TBL_NOTES}").to_pandas().iloc[0]["C"]
            st.caption(f"Current rows — tasks: **{cnt_t}**, assignees: **{cnt_a}**, notes: **{cnt_n}**")
        except Exception as e:
            st.caption(f"Could not read row counts: {e}")

        confirm_chk = st.checkbox("I understand this cannot be undone", key="dz_chk")
        typed = st.text_input("Type RESET ALL to confirm", key="dz_typed")
        if st.button("Reset all task data", type="primary",
                     disabled=not (confirm_chk and typed.strip() == "RESET ALL"),
                     key="dz_btn"):
            try:
                # Order matters: child tables first
                session.sql(f"DELETE FROM {TBL_NOTES}").collect()
                session.sql(f"DELETE FROM {TBL_ASSIGN}").collect()
                session.sql(f"DELETE FROM {TBL_TASKS}").collect()
                st.success("All task data reset. TEAM_MEMBERS preserved.")
                # Clear the confirm input so user can't re-run by accident
                st.session_state["dz_chk"] = False
                st.session_state["dz_typed"] = ""
                st.rerun()
            except Exception as e:
                st.error(f"Reset failed: {e}")


