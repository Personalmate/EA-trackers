DROP TABLE DB_CORE_PRD.BACKUP_OPS.TEAM_MEMBERS;

CREATE TABLE DB_CORE_PRD.BACKUP_OPS.TEAM_MEMBERS (
    MEMBER_ID        NUMBER           AUTOINCREMENT PRIMARY KEY,
    FULL_NAME        VARCHAR(200)     NOT NULL UNIQUE,
    SHORT_NAME       VARCHAR(100),
    SNOWFLAKE_USER   VARCHAR(200)     UNIQUE,
    ROLE             VARCHAR(50)      NOT NULL DEFAULT 'Contributor',
    ACTIVE_STATUS    VARCHAR(20)      NOT NULL DEFAULT 'Active',
    NOTES            VARCHAR(2000),
    CREATED_AT       TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP(),
    UPDATED_AT       TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP()
);
