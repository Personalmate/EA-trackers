-- ============================================================
-- Team Effort Tracker — v2 schema
-- Schema: DB_CORE_PRD.BACKUP_OPS
-- Safe to run alongside existing v1 tables; see migration notes.
-- ============================================================

-- 1. TEAM_MEMBERS (canonical people list — source of truth)
CREATE TABLE IF NOT EXISTS DB_CORE_PRD.BACKUP_OPS.TEAM_MEMBERS (
    MEMBER_ID        NUMBER           AUTOINCREMENT PRIMARY KEY,
    FULL_NAME        VARCHAR(200)     NOT NULL UNIQUE,        -- canonical display name, e.g. "Harry Smith"
    SHORT_NAME       VARCHAR(100),                             -- e.g. "Harry"
    SNOWFLAKE_USER   VARCHAR(200)     UNIQUE,                  -- matches CURRENT_USER(); NULL until first login
    ROLE             VARCHAR(50)      NOT NULL DEFAULT 'Contributor',  -- Contributor | Lead | Reviewer
    ACTIVE_STATUS    VARCHAR(20)      NOT NULL DEFAULT 'Active',       -- Active | Inactive
    NOTES            VARCHAR(2000),
    CREATED_AT       TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP(),
    UPDATED_AT       TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP()
);

-- 2. TASKS (no more OWNER string; assignees move to junction table)
CREATE TABLE IF NOT EXISTS DB_CORE_PRD.BACKUP_OPS.TASKS_V2 (
    TASK_ID              NUMBER           AUTOINCREMENT PRIMARY KEY,
    WORK_TYPE            VARCHAR(20)      NOT NULL,           -- 'Enhancement' | 'Automation'
    TITLE                VARCHAR(500)     NOT NULL,
    BUSINESS_REASON      VARCHAR(4000),                        -- parsed from "Why:"
    PLATFORM_AREA        VARCHAR(500),                         -- parsed from "Where:"
    REVIEWER_MEMBER_ID   NUMBER           REFERENCES TEAM_MEMBERS(MEMBER_ID),
    START_DATE           DATE,                                 -- NULL allowed; import preserves "TBD" as NULL with a flag in NOTES
    CLOSED_DATE          DATE,
    STATUS               VARCHAR(50)      NOT NULL DEFAULT 'Queued',  -- Queued | In Progress | On Hold | Closed | Cancelled
    EFFORT_DAYS          NUMBER(10,2)     DEFAULT 0,
    COMPLETION_PCT       NUMBER(5,2)      DEFAULT 0,
    JIRA_REFERENCE       VARCHAR(500),
    OVERFLOW_ASSIGNEES   VARCHAR(500),                         -- names beyond the 3 slots, comma-separated; flagged in UI
    IMPORT_NOTES         VARCHAR(2000),                        -- parser flags: "date ambiguous", "status was Pending(...)", etc.
    CREATED_BY_MEMBER_ID NUMBER           REFERENCES TEAM_MEMBERS(MEMBER_ID),
    CREATED_AT           TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP(),
    UPDATED_AT           TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP(),
    CONSTRAINT CK_WORK_TYPE CHECK (WORK_TYPE IN ('Enhancement','Automation')),
    CONSTRAINT CK_STATUS   CHECK (STATUS IN ('Queued','In Progress','On Hold','Closed','Cancelled')),
    CONSTRAINT CK_PCT      CHECK (COMPLETION_PCT BETWEEN 0 AND 100)
);

-- 3. TASK_ASSIGNEES junction (replaces OWNER free-text)
CREATE TABLE IF NOT EXISTS DB_CORE_PRD.BACKUP_OPS.TASK_ASSIGNEES (
    TASK_ID         NUMBER   NOT NULL REFERENCES TASKS_V2(TASK_ID),
    MEMBER_ID       NUMBER   NOT NULL REFERENCES TEAM_MEMBERS(MEMBER_ID),
    ASSIGNEE_ROLE   VARCHAR(20) NOT NULL,   -- 'primary' | 'secondary' | 'tertiary'
    CREATED_AT      TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP(),
    PRIMARY KEY (TASK_ID, MEMBER_ID),
    CONSTRAINT CK_ROLE CHECK (ASSIGNEE_ROLE IN ('primary','secondary','tertiary'))
);

-- 4. PROGRESS_NOTES (same idea as v1, now FK to MEMBER_ID for attribution)
CREATE TABLE IF NOT EXISTS DB_CORE_PRD.BACKUP_OPS.PROGRESS_NOTES_V2 (
    NOTE_ID          NUMBER           AUTOINCREMENT PRIMARY KEY,
    TASK_ID          NUMBER           NOT NULL REFERENCES TASKS_V2(TASK_ID),
    NOTE_TEXT        VARCHAR(4000)    NOT NULL,
    NOTE_DATE        DATE,                                     -- parsed from "25/06 :" prefix when present; else NULL
    CREATED_BY_MEMBER_ID NUMBER        REFERENCES TEAM_MEMBERS(MEMBER_ID),
    IS_IMPORTED      BOOLEAN          DEFAULT FALSE,
    CREATED_AT       TIMESTAMP_NTZ    DEFAULT CURRENT_TIMESTAMP()
);

-- Indexes for hot paths
CREATE INDEX IF NOT EXISTS IX_TASKS_V2_STATUS   ON TASKS_V2(STATUS);
CREATE INDEX IF NOT EXISTS IX_TASKS_V2_WORKTYPE ON TASKS_V2(WORK_TYPE);
CREATE INDEX IF NOT EXISTS IX_NOTES_V2_TASK     ON PROGRESS_NOTES_V2(TASK_ID);
CREATE INDEX IF NOT EXISTS IX_ASSIGN_MEMBER     ON TASK_ASSIGNEES(MEMBER_ID);



